rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper to validate the shape of portfolio data
    function isValidPortfolio(data) {
      return data.keys().hasAll([
        'projects', 
        'skills', 
        'software', 
        'experience', 
        'achievements', 
        'testimonials', 
        'gallery', 
        'profileInfo', 
        'processSteps'
      ]) && data.keys().size() == 9;
    }

    match /portfolio/main {
      // Anyone can read the portfolio to view the website
      allow read: if true;
      
      // Allow updates if the data is valid
      allow write: if isValidPortfolio(request.resource.data);
    }
  }
}
